<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Page not found — SwapNext</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/CSS/includes/navbar.css"/>
    <link rel="stylesheet" href="/CSS/errorPages/error.css"/>
</head>
<body>

    <%- include("../includes/navbar.ejs", { activePage: "", currUser: locals.currUser || null }) %>

  	<main class="ep-main">
		<div class="ep-container">

			<!-- Illustration -->
			<div class="ep-illustration" aria-hidden="true">
				<svg class="ep-svg" viewBox="0 0 480 320" fill="none" xmlns="http://www.w3.org/2000/svg">
					<!-- Ground shadow -->
					<ellipse cx="240" cy="300" rx="180" ry="12" fill="#F7F7F7"/>

					<!-- Left "4" -->
					<rect x="30" y="80" width="28" height="160" rx="6" fill="#DDDDDD"/>
					<rect x="30" y="80" width="100" height="28" rx="6" fill="#DDDDDD"/>
					<rect x="102" y="80" width="28" height="90" rx="6" fill="#DDDDDD"/>
					<rect x="30" y="142" width="130" height="28" rx="6" fill="#DDDDDD"/>

					<!-- Right "4" -->
					<rect x="322" y="80" width="28" height="160" rx="6" fill="#DDDDDD"/>
					<rect x="322" y="80" width="100" height="28" rx="6" fill="#DDDDDD"/>
					<rect x="394" y="80" width="28" height="90" rx="6" fill="#DDDDDD"/>
					<rect x="322" y="142" width="130" height="28" rx="6" fill="#DDDDDD"/>

					<!-- Zero / sad face -->
					<circle cx="240" cy="160" r="90" fill="#FF385C" opacity="0.08"/>
					<circle cx="240" cy="160" r="80" stroke="#FF385C" stroke-width="8" fill="white"/>

					<!-- Sad eyes -->
					<circle cx="210" cy="140" r="8" fill="#222222"/>
					<circle cx="270" cy="140" r="8" fill="#222222"/>

					<!-- Teardrop left eye -->
					<ellipse cx="210" cy="158" rx="4" ry="7" fill="#B0D4FF" opacity="0.7"/>

					<!-- Sad mouth -->
					<path d="M215 185 Q240 170 265 185" stroke="#222222" stroke-width="5" stroke-linecap="round" fill="none"/>

					<!-- Eyebrows sad -->
					<path d="M200 125 Q210 120 220 126" stroke="#222222" stroke-width="3.5" stroke-linecap="round" fill="none"/>
					<path d="M260 126 Q270 120 280 125" stroke="#222222" stroke-width="3.5" stroke-linecap="round" fill="none"/>

					<!-- Small broken tag floating -->
					<g transform="translate(310,50) rotate(-15)">
						<rect x="0" y="0" width="54" height="32" rx="6" fill="#FF385C" opacity="0.15"/>
						<circle cx="10" cy="16" r="4" fill="#FF385C" opacity="0.4"/>
						<line x1="18" y1="10" x2="46" y2="10" stroke="#FF385C" stroke-width="2.5" stroke-linecap="round" opacity="0.4"/>
						<line x1="18" y1="18" x2="38" y2="18" stroke="#FF385C" stroke-width="2.5" stroke-linecap="round" opacity="0.4"/>
						<line x1="18" y1="26" x2="42" y2="26" stroke="#FF385C" stroke-width="2.5" stroke-linecap="round" opacity="0.4"/>
					</g>

					<!-- Magnifying glass floating -->
					<g transform="translate(88,48) rotate(20)">
						<circle cx="22" cy="22" r="18" stroke="#DDDDDD" stroke-width="5" fill="white"/>
						<line x1="35" y1="35" x2="50" y2="50" stroke="#DDDDDD" stroke-width="5" stroke-linecap="round"/>
						<line x1="16" y1="22" x2="28" y2="22" stroke="#B0B0B0" stroke-width="2.5" stroke-linecap="round"/>
						<line x1="22" y1="16" x2="22" y2="28" stroke="#B0B0B0" stroke-width="2.5" stroke-linecap="round"/>
					</g>
				</svg>
			</div>

			<!-- Text -->
			<div class="ep-text">
				<span class="ep-code">404</span>
				<h1 class="ep-heading">Page not found</h1>
				<p class="ep-body">
					<% if (locals.message) { %>
						<%= message %>
					<% } else { %>
						Looks like this page took a wrong turn.
						The listing may have been removed, or the link is broken.
					<% } %>
				</p>
			</div>

			<!-- Actions -->
			<div class="ep-actions">
				<a href="/api/v1/listings" class="ep-btn ep-btn--primary">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
						<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
						<polyline points="9 22 9 12 15 12 15 22"/>
					</svg>
					Go to homepage
				</a>

				<a href="/api/v1/listings" class="ep-btn ep-btn--secondary">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
						<circle cx="11" cy="11" r="8"/>
						<line x1="21" y1="21" x2="16.65" y2="16.65"/>
					</svg>
					Browse listings
				</a>

				<button class="ep-btn ep-btn--ghost" onclick="history.back()">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
						<line x1="19" y1="12" x2="5" y2="12"/>
						<polyline points="12 19 5 12 12 5"/>
					</svg>
					Go back
				</button>
			</div>

			<!-- Popular categories shortcut -->
			<div class="ep-shortcuts">
				<p class="ep-shortcuts-label">Or explore by category</p>
				<div class="ep-shortcuts-row">
					<% [ ['electronics','Electronics'], ['vehicles','Vehicles'], ['furniture','Furniture'], ['clothing','Clothing'], ['sports','Sports'], ['books','Books'] ].forEach(([id, label]) => { %>
						<a href="/api/v1/?category=<%= id %>" class="ep-shortcut"><%= label %></a>
					<% }); %>
				</div>
			</div>

		</div>
  	</main>

</body>
</html>
