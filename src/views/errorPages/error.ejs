<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Something went wrong — SwapNext</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/CSS/includes/navbar.css"/>
    <link rel="stylesheet" href="/CSS/errorPages/error.css"/>
</head>
<body>

    <%- include("../includes/navbar.ejs", { activePage: "", currUser: locals.currUser || null }) %>

    <main class="ep-main">
        <div class="ep-container">

            <!-- Illustration -->
            <div class="ep-illustration" aria-hidden="true">
                <svg class="ep-svg" viewBox="0 0 480 320" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- Ground shadow -->
                    <ellipse cx="240" cy="300" rx="180" ry="12" fill="#F7F7F7"/>

                    <!-- Broken gear large -->
                    <g transform="translate(175, 70)">
                        <!-- Gear body -->
                        <circle cx="65" cy="90" r="52" fill="white" stroke="#DDDDDD" stroke-width="7"/>
                        <circle cx="65" cy="90" r="22" fill="white" stroke="#DDDDDD" stroke-width="7"/>
                        <!-- Gear teeth -->
                        <rect x="56" y="30" width="18" height="20" rx="4" fill="#DDDDDD"/>
                        <rect x="56" y="130" width="18" height="20" rx="4" fill="#DDDDDD"/>
                        <rect x="15" y="81" width="20" height="18" rx="4" fill="#DDDDDD"/>
                        <rect x="95" y="81" width="20" height="18" rx="4" fill="#DDDDDD"/>
                        <rect x="27" y="47" width="18" height="20" rx="4" transform="rotate(45 36 57)" fill="#DDDDDD"/>
                        <rect x="88" y="110" width="18" height="20" rx="4" transform="rotate(45 97 120)" fill="#DDDDDD"/>
                        <rect x="27" y="110" width="18" height="20" rx="4" transform="rotate(-45 36 120)" fill="#DDDDDD"/>
                        <rect x="88" y="47" width="18" height="20" rx="4" transform="rotate(-45 97 57)" fill="#DDDDDD"/>
                        <!-- Lightning bolt (error) inside -->
                        <path d="M72 68 L58 92 L68 92 L58 112 L82 84 L70 84 Z" fill="#FF385C" opacity="0.85"/>
                    </g>

                    <!-- Small gear top-right -->
                    <g transform="translate(330, 60) scale(0.55)">
                        <circle cx="50" cy="50" r="38" fill="white" stroke="#DDDDDD" stroke-width="6"/>
                        <circle cx="50" cy="50" r="14" fill="white" stroke="#DDDDDD" stroke-width="6"/>
                        <rect x="42" y="4"  width="16" height="16" rx="3" fill="#DDDDDD"/>
                        <rect x="42" y="80" width="16" height="16" rx="3" fill="#DDDDDD"/>
                        <rect x="4"  y="42" width="16" height="16" rx="3" fill="#DDDDDD"/>
                        <rect x="80" y="42" width="16" height="16" rx="3" fill="#DDDDDD"/>
                    </g>

                    <!-- Small gear bottom-left -->
                    <g transform="translate(60, 160) scale(0.45)">
                        <circle cx="50" cy="50" r="38" fill="white" stroke="#DDDDDD" stroke-width="6"/>
                        <circle cx="50" cy="50" r="14" fill="white" stroke="#DDDDDD" stroke-width="6"/>
                        <rect x="42" y="4"  width="16" height="16" rx="3" fill="#DDDDDD"/>
                        <rect x="42" y="80" width="16" height="16" rx="3" fill="#DDDDDD"/>
                        <rect x="4"  y="42" width="16" height="16" rx="3" fill="#DDDDDD"/>
                        <rect x="80" y="42" width="16" height="16" rx="3" fill="#DDDDDD"/>
                    </g>

                    <!-- Error code chip -->
                    <rect x="178" y="232" width="124" height="36" rx="18" fill="#FF385C" opacity="0.1"/>
                    <text x="240" y="255" text-anchor="middle" font-family="monospace"
                            font-size="14" font-weight="700" fill="#FF385C">500 ERROR</text>

                    <!-- Wrench floating -->
                    <g transform="translate(52,58) rotate(-30)">
                        <rect x="0" y="10" width="60" height="14" rx="7" fill="#DDDDDD"/>
                        <circle cx="8"  cy="17" r="12" fill="white" stroke="#DDDDDD" stroke-width="4"/>
                        <circle cx="52" cy="17" r="9"  fill="white" stroke="#DDDDDD" stroke-width="4"/>
                    </g>
                </svg>
            </div>

            <!-- Text -->
            <div class="ep-text">
                <span class="ep-code">500</span>
                <h1 class="ep-heading">Something went wrong</h1>
                <p class="ep-body">
                    <% if (locals.message) { %>
                        <%= message %>
                    <% } else { %>
                        Our servers hit a snag. This is on us — please try again
                        in a moment. If the problem persists, contact support.
                    <% } %>
                </p>
            </div>

            <!-- Actions -->
            <div class="ep-actions">
                <button class="ep-btn ep-btn--primary" onclick="location.reload()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                        <polyline points="23 4 23 10 17 10"/>
                        <polyline points="1 20 1 14 7 14"/>
                        <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
                    </svg>
                    Try again
                </button>
                <a href="/api/v1/listings" class="ep-btn ep-btn--secondary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    Go to homepage
                </a>
                <button class="ep-btn ep-btn--ghost" onclick="history.back()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                        <line x1="19" y1="12" x2="5" y2="12"/>
                        <polyline points="12 19 5 12 12 5"/>
                    </svg>
                    Go back
                </button>
            </div>

            <!-- Status link -->
            <p class="ep-status-link">
                Check our <a href="/status">service status page</a> for known outages.
            </p>

        </div>
    </main>

</body>
</html>
