<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | SwapNest</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/includes/navbar.css">
    <link rel="stylesheet" href="/CSS/includes/footer.css">
    <link rel="stylesheet" href="/CSS/userPages/login.css">
</head>
<body class="bg-light">

    <%- include('../includes/navbar') %>

    <div class="login-container">
        <div class="login-card">
            <div class="text-center">
                <i class="fa-solid fa-repeat brand-icon"></i>
                <h2 class="login-title">Welcome Back</h2>
                <p class="text-muted mb-4">Login to your SwapNest account</p>
            </div>

            <% if (locals.error) { %>
                <div class="validation-error mb-3">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>
                    <%= error %>
                </div>
            <% } %>

            <form action="/api/v1/users/login" method="POST">
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="email" name="email" class="form-control" placeholder="Enter your email">
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" placeholder="••••••••">
                    <div class="text-end mt-1">
                        <a href="#" class="login-link small">Forgot password?</a>
                    </div>
                </div>

                <button type="submit" class="btn-login w-100">Login</button>
            </form>

            <div class="text-center mt-4">
                <p class="small text-muted">Don't have an account? 
                    <a href="/api/v1/users/signup" class="login-link">Sign Up</a>
                </p>
            </div>
        </div>
    </div>

    <%- include('../includes/footer') %>
    <script src="/SCRIPT/formValidation.js"></script>
    <script src="/SCRIPT/navBar.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>