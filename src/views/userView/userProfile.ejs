<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/style.css">
    <link rel="stylesheet" href="/CSS/userPages/profile.css">
</head>
<body>

    <%- include('includes/navbar.ejs') %>

    <div class="profile-wrapper">
        <div class="container py-5">
            <div class="row g-4">
                
                <aside class="col-lg-3 col-md-4">
                    <div class="sidebar-card">
                        <h1 class="h3 fw-bold mb-4">Profile</h1>
                        <ul class="nav flex-column sidebar-nav">
                            <li class="nav-item active">
                                <div class="nav-link">
                                    <span class="icon-circle">D</span>
                                    <span>About me</span>
                                </div>
                            </li>
                            <li class="nav-item">
                                <div class="nav-link">
                                    <i class="fa-solid fa-suitcase-rolling"></i>
                                    <span>Past trips</span>
                                </div>
                            </li>
                            <li class="nav-item">
                                <div class="nav-link">
                                    <i class="fa-solid fa-users"></i>
                                    <span>Connections</span>
                                </div>
                            </li>
                        </ul>
                    </div>
                </aside>

                <main class="col-lg-9 col-md-8">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="fw-bold">About me</h2>
                        <button class="btn btn-outline-dark rounded-pill px-4 btn-sm fw-bold">Edit Profile</button>
                    </div>

                    <div class="row g-4">
                        <div class="col-xl-5 col-lg-6">
                            <div class="user-id-card">
                                <div class="avatar-container">
                                    <% if (currUser.avatar) { %>
                                        <img src="<%= currUser.avatar.replace('/upload/', '/upload/w_300,h_300,c_fill,g_face/') %>" alt="User" class="avatar-img">
                                    <% } else { %>
                                        <div class="avatar-initials">
                                            <%= currUser.fullName.slice(0, 1).toUpperCase() %>
                                        </div>
                                    <% } %>
                                </div>
                                <h3 class="mt-3 mb-0 fw-bold"><%= currUser.fullName %></h3>
                                <p class="text-muted">Guest</p>
                            </div>
                        </div>

                        <div class="col-xl-7 col-lg-6">
                            <div class="cta-card h-100">
                                <h4 class="fw-bold">Complete your profile</h4>
                                <p class="text-secondary small">Your SwapNext profile is an important part of every reservation. Help hosts and guests get to know you.</p>
                                <button class="btn btn-primary-airbnb mt-auto">Get started</button>
                            </div>
                        </div>
                    </div>

                    <hr class="my-5 opacity-10">

                    <div class="review-section">
                        <div class="d-flex align-items-center gap-2 text-dark fw-bold">
                            <i class="fa-regular fa-comment-dots fs-4"></i>
                            <span>Reviews I've written</span>
                        </div>
                    </div>
                </main>

            </div>
        </div>
    </div>
    
    <%- include('includes/footer.ejs') %>

    <script src="/SCRIPT/formValidation.js"></script>
    <script src="/SCRIPT/navBar.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>












